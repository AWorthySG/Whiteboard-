# --- Supabase ---
# Project URL and anon key from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- LiveKit ---
# Public URL of your LiveKit server (e.g. wss://your-project.livekit.cloud)
NEXT_PUBLIC_LIVEKIT_URL=
# API key/secret from your LiveKit project for issuing room tokens
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- tldraw sync (Cloudflare Worker) ---
# WebSocket URL for the deployed sync Worker, e.g. wss://whiteboard-sync.<account>.workers.dev
NEXT_PUBLIC_TLDRAW_SYNC_URL=
# Optional: tldraw commercial license key (from https://tldraw.dev). When
# set, removes the 'Made with tldraw' watermark from the canvas.
NEXT_PUBLIC_TLDRAW_LICENSE_KEY=
